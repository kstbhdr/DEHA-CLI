{
  "name": "deha-cli",
  "version": "1.0.7",
  "description": "DEHA - Akıllı AI Kodlama Asistanı CLI | Multi-model: Claude, OpenAI, DeepSeek, Ollama",
  "main": "dist/index.js",
  "bin": {
    "deha": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "cli",
    "ai",
    "deha",
    "claude",
    "openai",
    "deepseek",
    "ollama",
    "coding-assistant",
    "turkish",
    "developer-tools"
  ],
  "author": "DEHA Project",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/cheerio": "^0.22.35",
    "axios": "^1.15.2",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "chromadb": "^3.4.3",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "inquirer": "^8.2.6",
    "ioredis": "^5.10.1",
    "ora": "^5.4.1",
    "playwright": "^1.59.1",
    "readline": "^1.3.0",
    "redis-memory-server": "^0.16.1"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^4.1.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2",
    "vitest": "^4.1.5"
  }
}
