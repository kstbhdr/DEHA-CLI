# ─────────────────────────────────────────────────────────────────
#  DEHA CLI - Ortam Değişkenleri
# ─────────────────────────────────────────────────────────────────

# ── İnteraktif mod default provider ──────────────────────────────
# claude | openai | deepseek | ollama | openrouter | xai
DEHA_PROVIDER=claude

# ── API Keyleri (global) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
XAI_API_KEY=xai-...

# ── Modeller (global) ─────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6
OPENAI_MODEL=gpt-4o
DEEPSEEK_MODEL=deepseek-chat
OPENROUTER_MODEL=anthropic/claude-opus-4
XAI_MODEL=grok-3

# ── Ollama (yerel) ────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Custom API (kendi GPU sunucun, LM Studio, vLLM, LocalAI vb.) ──
# OpenAI-uyumlu herhangi bir endpoint çalışır
CUSTOM_API_URL=http://localhost:8080/v1
CUSTOM_API_KEY=                        # opsiyonel, boş bırakılabilir
CUSTOM_MODEL=local-model               # modelin adı (sunucudan öğren)

# ── Genel ayarlar ─────────────────────────────────────────────────
DEHA_SYSTEM_PROMPT=Sen DEHA adlı zeki bir kodlama asistanısın. Türkçe sorulara Türkçe, İngilizce sorulara İngilizce yanıt ver.
DEHA_MAX_TOKENS=4096
DEHA_TEMPERATURE=0.7

# ═════════════════════════════════════════════════════════════════
#  PIPELINE KONFİGÜRASYONU (Plan → Code → Judge)
# ═════════════════════════════════════════════════════════════════

# ── PLANNER (Mimari düşünür, plan çıkarır) ────────────────────────
# Önerilen: Opus, GPT-4o, openrouter üzerinden büyük model
PLANNER_PROVIDER=openrouter
PLANNER_MODEL=anthropic/claude-opus-4
PLANNER_API_KEY=          # boşsa global OPENROUTER_API_KEY kullanılır
PLANNER_MAX_TOKENS=2048
PLANNER_TEMPERATURE=0.3

# ── CODER (Kodu yazar) ────────────────────────────────────────────
# Önerilen: DeepSeek, hız/fiyat dengesi iyi
CODER_PROVIDER=deepseek
CODER_MODEL=deepseek-chat
CODER_API_KEY=            # boşsa global DEEPSEEK_API_KEY kullanılır
CODER_MAX_TOKENS=8192
CODER_TEMPERATURE=0.2

# ── JUDGE (Kodu inceler, PASS/FAIL verir) ─────────────────────────
# Önerilen: xAI Grok reasoning, güçlü analiz
JUDGE_PROVIDER=xai
JUDGE_MODEL=grok-3
JUDGE_API_KEY=            # boşsa global XAI_API_KEY kullanılır
JUDGE_MAX_TOKENS=2048
JUDGE_TEMPERATURE=0.1

# ── Pipeline genel ────────────────────────────────────────────────
PIPELINE_MAX_ITERATIONS=3  # Judge FAIL derse max kaç kez tekrar yazılır

# ═════════════════════════════════════════════════════════════════
#  VISION KONFİGÜRASYONU
# ═════════════════════════════════════════════════════════════════
VISION_PROVIDER=claude                  # claude | openai | custom
VISION_MODEL=claude-opus-4-6
VISION_API_KEY=                         # boşsa global key kullanılır
VISION_API_URL=                         # custom endpoint için

# ═════════════════════════════════════════════════════════════════
#  FİYATLANDIRMA (USD / milyon token) — deha stats için
#  Güncel fiyatlar için provider'ın sayfasını kontrol et.
# ═════════════════════════════════════════════════════════════════

# Claude (Anthropic) — https://www.anthropic.com/pricing
CLAUDE_INPUT_PRICE=3.00
CLAUDE_OUTPUT_PRICE=15.00

# OpenAI — https://openai.com/pricing
OPENAI_INPUT_PRICE=2.50
OPENAI_OUTPUT_PRICE=10.00

# DeepSeek — https://platform.deepseek.com/docs/pricing
DEEPSEEK_INPUT_PRICE=0.27
DEEPSEEK_OUTPUT_PRICE=1.10

# OpenRouter — model bazında değişir, ortalama bir değer gir
OPENROUTER_INPUT_PRICE=3.00
OPENROUTER_OUTPUT_PRICE=15.00

# xAI (Grok) — https://x.ai/api
XAI_INPUT_PRICE=5.00
XAI_OUTPUT_PRICE=15.00
