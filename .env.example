# ─────────────────────────────────────────────────────────────────
#  DEHA CLI - Ortam Değişkenleri
# ─────────────────────────────────────────────────────────────────

# ── İnteraktif mod default provider ──────────────────────────────
# claude | openai | deepseek | ollama | openrouter | xai
DEHA_PROVIDER=claude

# ── API Keyleri (global) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
XAI_API_KEY=xai-...

# DeepSeek thinking mode
# Docs: https://api-docs.deepseek.com/guides/thinking_mode
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=high

# ── Modeller (global) ─────────────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-6
OPENAI_MODEL=gpt-4o
DEEPSEEK_MODEL=deepseek-v4-flash
OPENROUTER_MODEL=anthropic/claude-opus-4
XAI_MODEL=grok-3

# ── Ollama (yerel) ────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Custom API (kendi GPU sunucun, LM Studio, vLLM, LocalAI vb.) ──
# OpenAI-uyumlu herhangi bir endpoint çalışır
CUSTOM_API_URL=http://localhost:8080/v1
CUSTOM_API_KEY=                        # opsiyonel, boş bırakılabilir
CUSTOM_MODEL=local-model               # modelin adı (sunucudan öğren)

# ── Genel ayarlar ─────────────────────────────────────────────────
DEHA_SYSTEM_PROMPT=Sen DEHA adlı zeki bir kodlama asistanısın. Türkçe sorulara Türkçe, İngilizce sorulara İngilizce yanıt ver.
DEHA_MAX_TOKENS=4096
DEHA_TEMPERATURE=0.7

DEHA_MAX_TOOL_ROUNDS=200              # Agent modda maksimum tool calling turu
DEHA_TOOL_MAX_TOKENS=49152           # Tool calling için max token (48k)
DEHA_TOOL_STUCK_WINDOW=50            # Döngü tespiti için bakılan son tool sayısı
DEHA_TOOL_STUCK_THRESHOLD=20         # Aynı tool/input bu sayıya ulaşınca durur; 0 = kapalı
DEHA_BROWSER_STUCK_THRESHOLD=50      # Browser action için ayrı, daha gevşek döngü eşiği

# ── Context yönetimi (auto-compress) ────────────────────────────────
DEHA_MAX_CONTEXT_TOKENS=0            # 0 = provider/model'e göre otomatik tespit
DEHA_COMPRESS_THRESHOLD=0.75         # Context %75 dolunca otomatik özetleme
DEHA_MIN_HOT_MESSAGES=10             # Compress sırasında korunan minimum mesaj sayısı

# ═════════════════════════════════════════════════════════════════
#  PIPELINE KONFİGÜRASYONU (Plan → Code → Judge)
# ═════════════════════════════════════════════════════════════════

# ── PLANNER (Mimari düşünür, plan çıkarır) ────────────────────────
# Önerilen: Opus, GPT-4o, openrouter üzerinden büyük model
PLANNER_PROVIDER=openrouter
PLANNER_MODEL=anthropic/claude-opus-4
PLANNER_API_KEY=          # boşsa global OPENROUTER_API_KEY kullanılır
PLANNER_MAX_TOKENS=2048
PLANNER_TEMPERATURE=0.3

# ── CODER (Kodu yazar) ────────────────────────────────────────────
# Önerilen: DeepSeek, hız/fiyat dengesi iyi
CODER_PROVIDER=deepseek
CODER_MODEL=deepseek-v4-flash
CODER_API_KEY=            # boşsa global DEEPSEEK_API_KEY kullanılır
CODER_MAX_TOKENS=8192
CODER_TEMPERATURE=0.2

# ── JUDGE (Kodu inceler, PASS/FAIL verir) ─────────────────────────
# Önerilen: xAI Grok reasoning, güçlü analiz
JUDGE_PROVIDER=xai
JUDGE_MODEL=grok-3
JUDGE_API_KEY=            # boşsa global XAI_API_KEY kullanılır
JUDGE_MAX_TOKENS=2048
JUDGE_TEMPERATURE=0.1

# ── Pipeline genel ────────────────────────────────────────────────
PIPELINE_MAX_ITERATIONS=5    # Judge FAIL derse max kaç kez tekrar yazılır

# ═════════════════════════════════════════════════════════════════
#  VISION KONFİGÜRASYONU
# ═════════════════════════════════════════════════════════════════
VISION_PROVIDER=openrouter             # openrouter | openai | claude | custom
VISION_MODEL=qwen/qwen3-vl-32b-instruct
VISION_API_KEY=                         # boşsa global key kullanılır
VISION_API_URL=                         # custom endpoint için

# ═════════════════════════════════════════════════════════════════
#  FİYATLANDIRMA (USD / milyon token) — deha stats için
#  Güncel fiyatlar için provider'ın sayfasını kontrol et.
# ═════════════════════════════════════════════════════════════════

# Her rolün kullandığı modelin fiyatını gir (USD / milyon token)
# Hangi modeli kullandığını yukarıdaki PLANNER/CODER/JUDGE ayarlarından görebilirsin.

CHAT_INPUT_PRICE=3.00        # DEHA_PROVIDER'ın fiyatı
CHAT_OUTPUT_PRICE=15.00

PLANNER_INPUT_PRICE=3.00     # PLANNER_PROVIDER'ın fiyatı
PLANNER_OUTPUT_PRICE=15.00

CODER_INPUT_PRICE=0.27       # CODER_PROVIDER'ın fiyatı
CODER_OUTPUT_PRICE=1.10

JUDGE_INPUT_PRICE=5.00       # JUDGE_PROVIDER'ın fiyatı
JUDGE_OUTPUT_PRICE=15.00

VISION_INPUT_PRICE=3.00      # VISION_PROVIDER'ın fiyatı
VISION_OUTPUT_PRICE=15.00

AGENT_INPUT_PRICE=3.00       # Agent modu fiyatı
AGENT_OUTPUT_PRICE=15.00
